# --- General Configuration ---
NODE_ENV=production
PORT=3000

# --- Database Configuration ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=ticketz
DB_PASS=strong_password_here
DB_NAME=ticketz

# --- Redis Configuration ---
REDIS_URI=redis://redis:6379

# --- Authentication ---
# Generate long random strings for these
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
ENV_TOKEN=your_internal_api_token

# --- External Access ---
# This is what the browser will use to connect to your backend
BACKEND_PROTOCOL=http
BACKEND_HOST=your_server_ip_or_domain
BACKEND_PORT=8080
BACKEND_PATH=
BACKEND_URL=http://your_server_ip_or_domain:8080

# --- Frontend Configuration ---
FRONTEND_URL=http://localhost:3000

# --- Socket Admin (Optional) ---
SOCKET_ADMIN=true
SOCKET_ADMIN_USER=admin
SOCKET_ADMIN_PASSWORD=change_this_immediately

# --- Sentry (Optional) ---
# SENTRY_DSN=your_sentry_dsn
